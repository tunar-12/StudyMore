<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" style="-fx-background-color: rgba(0, 0, 0, 0.7);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" prefWidth="380.0" spacing="24.0" style="-fx-background-color: black; -fx-border-color: #d9534f; -fx-border-width: 2; -fx-padding: 32; -fx-background-radius: 8; -fx-border-radius: 8;">
         <children>
            <Label style="-fx-text-fill: #d9534f; -fx-font-weight: bold; -fx-font-size: 18;" text="NOT ENOUGH COINS" />
            
            <Label fx:id="errorMessageLabel" style="-fx-text-fill: #a3a3a3; -fx-font-size: 14;" text="You need more coins." wrapText="true" />

            <HBox VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_RIGHT">
               <children>
                  <Button fx:id="errorOkButton" prefWidth="100.0" style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 24; -fx-cursor: hand;" text="OK" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>