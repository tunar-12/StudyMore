<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="cardRoot" prefHeight="180.0" prefWidth="250.0" spacing="12.0" style="-fx-background-color: #1a1a1a; -fx-background-radius: 10; -fx-border-color: #333; -fx-border-radius: 10;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER_LEFT">
         <children>
            <Label fx:id="taskTitle" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" text="TASK TITLE" />
            <Region HBox.hgrow="ALWAYS" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: #555;" text="⋮" />
         </children>
      </HBox>
      
      <Label fx:id="taskContent" alignment="TOP_LEFT" prefHeight="65.0" style="-fx-text-fill: #999; -fx-font-size: 11;" text="Task details go here..." wrapText="true" />
      
      <Separator opacity="0.1" />
      
      <AnchorPane VBox.vgrow="ALWAYS">
         <children>
            <VBox fx:id="srsBadgeContainer" managed="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
               <children>
                  <Label style="-fx-text-fill: #555; -fx-font-size: 9; -fx-font-weight: bold;" text="RECALL IN" />
                  <Label fx:id="recallLabel" style="-fx-background-color: #333; -fx-text-fill: white; -fx-font-size: 10; -fx-font-weight: bold; -fx-padding: 3 8 3 8; -fx-background-radius: 3;" text="4 DAYS" />
               </children>
            </VBox>
            
            <Button fx:id="completeBtn" prefHeight="32.0" prefWidth="32.0" style="-fx-background-color: transparent; -fx-border-color: #444; -fx-border-radius: 5;" text="✓" textFill="WHITE" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0" />
         </children>
      </AnchorPane>
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</VBox>