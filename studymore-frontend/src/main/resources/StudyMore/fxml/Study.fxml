<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="StudyMore.controllers.StudyController">
   <children>
      
      <HBox spacing="32.0" style="-fx-padding: 32;">
         <children>
            
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <VBox alignment="CENTER" maxWidth="500.0" prefHeight="350.0" spacing="48.0" style="-fx-background-color: black; -fx-border-color: #262626;">
                     <children>
                        <Label fx:id="timerLabel" text="00:00" textFill="WHITE">
                           <font>
                              <Font name="Monospaced Bold" size="96.0" />
                           </font>
                        </Label>
                        <HBox alignment="CENTER" spacing="16.0">
                           <children>
                              <Button fx:id="timerControlButton" mnemonicParsing="false" onAction="#timerController" style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-padding: 12 24;" text="START">
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Button>
                              <Button fx:id="shortBreakButton" mnemonicParsing="false" onAction="#shortBreak" style="-fx-background-color: transparent; -fx-border-color: #404040; -fx-text-fill: #d4d4d4; -fx-padding: 11 24;" text="SHORT BREAK">
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Button>
                              <Button fx:id="longBreakButton" mnemonicParsing="false" onAction="#longBreak" style="-fx-background-color: transparent; -fx-border-color: #404040; -fx-text-fill: #d4d4d4; -fx-padding: 11 24;" text="LONG BREAK">
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>

            <VBox prefWidth="320.0" spacing="24.0">
               <children>
                  
                  <HBox spacing="16.0">
                     <children>
                        <VBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: black; -fx-border-color: #262626;" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="STREAK" textFill="#737373">
                                 <font><Font size="10.0" /></font>
                              </Label>
                              <Label text="0 Days" textFill="WHITE" fx:id="streakLabel">
                                 <font><Font name="System Bold" size="20.0" /></font>
                              </Label>
                           </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: black; -fx-border-color: #262626;" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="MULTIPLIER" textFill="#737373">
                                 <font><Font size="10.0" /></font>
                              </Label>
                              <Label text="1.0x" textFill="WHITE" fx:id="multiplierLabel">
                                 <font><Font name="System Bold" size="20.0" /></font>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <VBox prefHeight="0.0" style="-fx-background-color: black; -fx-border-color: #262626;" VBox.vgrow="ALWAYS">
                     <children>
                        <HBox style="-fx-background-color: #171717; -fx-padding: 16 20; -fx-border-color: transparent transparent #262626 transparent;">
                           <children>
                              <Label text="TASK RECALL" textFill="WHITE">
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Label>
                           </children>
                        </HBox>
                        
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                           <content>
                              <VBox fx:id="studyTasksContainer" spacing="12.0" style="-fx-padding: 20; -fx-background-color: black;" />
                           </content>
                        </ScrollPane>

                     </children>
                  </VBox>

                  <VBox prefHeight="0.0" style="-fx-background-color: black; -fx-border-color: #262626;" VBox.vgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #171717; -fx-padding: 16 20; -fx-border-color: transparent transparent #262626 transparent;">
                           <children>
                              <Label text="LEADERBOARD" textFill="WHITE">
                                 <font><Font name="System Bold" size="14.0" /></font>
                              </Label>
                              <AnchorPane HBox.hgrow="ALWAYS" />
                              <Label fx:id="goal" style="-fx-background-color: white; -fx-padding: 4 8;" text="Goal: No Study Group" textFill="BLACK">
                                 <font><Font name="System Bold" size="10.0" /></font>
                              </Label>
                           </children>
                        </HBox>
                        
                        <VBox spacing="8.0" style="-fx-padding: 20; -fx-background-color: black;" VBox.vgrow="ALWAYS">
                           <children>
                              <HBox style="-fx-background-color: white; -fx-padding: 12;">
                                 <children>
                                    <Label fx:id="userRankLabel" text="-. You" textFill="BLACK">
                                       <font><Font name="System Bold" size="14.0" /></font>
                                    </Label>
                                    <AnchorPane HBox.hgrow="ALWAYS" />
                                    <Label fx:id="studyTime" text="0H" textFill="BLACK">
                                       <font><Font name="Monospaced Bold" size="14.0" /></font>
                                    </Label>
                                 </children>
                              </HBox>
                              
                              <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                                 <content>
                                    <VBox fx:id="leaderboardContainer" spacing="8.0" style="-fx-background-color: black;" />
                                 </content>
                              </ScrollPane>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

               </children>
            </VBox>
         </children>
      </HBox>

      <AnchorPane pickOnBounds="false">
         <children>
            <AnchorPane AnchorPane.bottomAnchor="32.0" AnchorPane.leftAnchor="32.0">
               <children>
                  <ImageView fx:id="catHouse" fitHeight="96.0" fitWidth="96.0" pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" />
                  <ImageView fx:id="catSkin" fitHeight="96.0" fitWidth="96.0" pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="64.0" AnchorPane.leftAnchor="0.0" />
                  
                  <AnchorPane AnchorPane.bottomAnchor="140.0" AnchorPane.leftAnchor="70.0">
                     <children>
                        
                        <VBox alignment="CENTER" maxWidth="200.0" style="-fx-background-color: #171717; -fx-border-color: #404040; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 12 16;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                           <children>
                              <Label fx:id="catQuoteLabel" text="Loading..." textFill="#e5e5e5" wrapText="true">
                                 <font>
                                    <Font name="System Bold" size="13.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>

                        <AnchorPane prefHeight="14.0" prefWidth="14.0" rotate="45.0" style="-fx-background-color: #171717; -fx-border-color: transparent #404040 #404040 transparent;" AnchorPane.bottomAnchor="-7.0" AnchorPane.leftAnchor="12.0" />
                        
                     </children>
                  </AnchorPane>

               </children>
            </AnchorPane>
         </children>
      </AnchorPane>
      
   </children>
</StackPane>