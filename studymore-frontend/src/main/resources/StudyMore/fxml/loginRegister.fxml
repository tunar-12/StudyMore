<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="StudyMore.controllers.LoginRegisterController"
           style="-fx-background-color: #000000;"
           prefHeight="800.0" prefWidth="1200.0">

    <HBox alignment="CENTER" spacing="32.0">
        
        <VBox alignment="CENTER" prefWidth="400.0" prefHeight="550.0" spacing="24.0" 
              style="-fx-background-color: #000000; -fx-border-color: #262626; -fx-border-width: 1px; -fx-padding: 48px;">
            
            <Label text="LOGIN" 
                   style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Monospaced';">
                <font>
                    <Font name="Monospaced Bold" size="28.0" />
                </font>
            </Label>

            <VBox spacing="8.0" alignment="CENTER_LEFT">
                <Label text="USERNAME" style="-fx-text-fill: #737373; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 4 0;" />
                <TextField fx:id="loginUsernameField" 
                           style="-fx-background-color: #000000; -fx-border-color: #525252; -fx-text-fill: #ffffff; -fx-padding: 10px; -fx-font-size: 14px;" />
            </VBox>

            <VBox spacing="8.0" alignment="CENTER_LEFT">
                <Label text="PASSWORD" style="-fx-text-fill: #737373; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 4 0;" />
                <PasswordField fx:id="loginPasswordField" 
                               style="-fx-background-color: #000000; -fx-border-color: #525252; -fx-text-fill: #ffffff; -fx-padding: 10px; -fx-font-size: 14px;" />
            </VBox>

            <Button onAction="#handleLogin" text="LOGIN" 
                    style="-fx-background-color: transparent; -fx-border-color: #404040; -fx-text-fill: #d4d4d4; -fx-font-weight: bold; -fx-padding: 12px 16px; -fx-cursor: hand;"
                    prefWidth="200.0" />
        </VBox>

        <VBox alignment="CENTER" prefWidth="400.0" prefHeight="550.0" spacing="24.0" 
              style="-fx-background-color: #000000; -fx-border-color: #262626; -fx-border-width: 1px; -fx-padding: 48px;">
            
            <Label text="REGISTER" 
                   style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Monospaced';">
                <font>
                    <Font name="Monospaced Bold" size="28.0" />
                </font>
            </Label>

            <VBox spacing="8.0" alignment="CENTER_LEFT">
                <Label text="USERNAME" style="-fx-text-fill: #737373; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 4 0;" />
                <TextField fx:id="registerUsernameField" 
                           style="-fx-background-color: #000000; -fx-border-color: #525252; -fx-text-fill: #ffffff; -fx-padding: 10px; -fx-font-size: 14px;" />
            </VBox>

            <VBox spacing="8.0" alignment="CENTER_LEFT">
                <Label text="EMAIL" style="-fx-text-fill: #737373; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 4 0;" />
                <TextField fx:id="registerEmailField" 
                           style="-fx-background-color: #000000; -fx-border-color: #525252; -fx-text-fill: #ffffff; -fx-padding: 10px; -fx-font-size: 14px;" />
            </VBox>

            <VBox spacing="8.0" alignment="CENTER_LEFT">
                <Label text="PASSWORD" style="-fx-text-fill: #737373; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 4 0;" />
                <PasswordField fx:id="registerPasswordField" 
                               style="-fx-background-color: #000000; -fx-border-color: #525252; -fx-text-fill: #ffffff; -fx-padding: 10px; -fx-font-size: 14px;" />
            </VBox>

            <Button onAction="#handleRegister" text="REGISTER" 
                    style="-fx-background-color: #ffffff; -fx-text-fill: #000000; -fx-font-weight: bold; -fx-padding: 12px 16px; -fx-cursor: hand;"
                    prefWidth="200.0" />
        </VBox>

    </HBox>
</StackPane>