<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" style="-fx-background-color: rgba(0, 0, 0, 0.7);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" prefWidth="550.0" spacing="24.0" style="-fx-background-color: black; -fx-border-color: #262626; -fx-padding: 32;">
         <children>
            
            <VBox spacing="8.0" alignment="CENTER">
                <children>
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18;" text="REVIEW COMPLETE" />
                    <Label style="-fx-text-fill: #737373; -fx-font-size: 13;" text="How difficult was it to remember this task? This action is irreversible." wrapText="true" />
                </children>
            </VBox>

            <HBox alignment="CENTER" spacing="12.0">
               <children>
                  <Button fx:id="blackoutBtn" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent; -fx-border-color: #404040; -fx-text-fill: #d9534f; -fx-font-weight: bold; -fx-padding: 12 0; -fx-cursor: hand;" text="BLACKOUT" />
                  
                  <Button fx:id="hardBtn" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent; -fx-border-color: #404040; -fx-text-fill: #f0ad4e; -fx-font-weight: bold; -fx-padding: 12 0; -fx-cursor: hand;" text="HARD" />
                  
                  <Button fx:id="mediumBtn" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent; -fx-border-color: #404040; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 0; -fx-cursor: hand;" text="MEDIUM" />
                  
                  <Button fx:id="goodBtn" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent; -fx-border-color: #404040; -fx-text-fill: #5bc0de; -fx-font-weight: bold; -fx-padding: 12 0; -fx-cursor: hand;" text="GOOD" />
                  
                  <Button fx:id="easyBtn" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent; -fx-border-color: #404040; -fx-text-fill: #4CAF50; -fx-font-weight: bold; -fx-padding: 12 0; -fx-cursor: hand;" text="EASY" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>